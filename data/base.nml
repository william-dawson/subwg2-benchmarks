&calculation
  theory = 'dft'  
/

&control
  sysname = 'SiO2'
/

&parallel
/

&rgrid
/

&units
  unit_system='A_eV_fs'
/

&system
  yn_periodic = 'y'
/


&pseudo
  izatom(1)=14
!-- psp8 pseudopotential from abinit web-site --
  file_pseudo(1) = './Si.psp8'
  lloc_ps(1)=4
  izatom(2)=8
  file_pseudo(2) = './O.psp8'
  lloc_ps(2)=4
/

&functional
  xc ='PZ'
/

&scf
  method_init_wf = 'random'
  ncg = 5
  nscf = 100
  threshold=-1
  alpha_mb= 0.30d0
/

&tgrid
 nt=6000
 dt=0.0005d0
/
